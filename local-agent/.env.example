# Public HTTPS origin of the deployed relay. No trailing slash.
RELAY_URL=https://photoshop-gpt-bridge.onrender.com

# Must match PHOTOSHOP_DEVICE_TOKEN configured on the relay host.
PHOTOSHOP_DEVICE_TOKEN=replace-with-your-device-token

# Dedicated folder containing replacement assets and receiving output copies.
WORKING_FOLDER=C:\Users\YOUR_NAME\Documents\PhotoshopBridge

# Polling interval in seconds.
POLL_SECONDS=2
