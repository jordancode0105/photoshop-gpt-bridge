PORT=3000

# Used by the private Custom GPT Action.
GPT_ACTION_API_KEY=replace-with-a-long-random-secret

# Used only by the local Photoshop PowerShell agent (and the optional legacy panel).
PHOTOSHOP_DEVICE_TOKEN=replace-with-a-different-long-random-secret

# Jobs are held in memory for this starter MVP.
JOB_TTL_MINUTES=60
